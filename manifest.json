{
  "manifest_version": 3,
  "name": "Tab Workspace Manager - By WindManager",
  "key": "",
  "version": "1.0.0",
  "description": "Manage named workspaces, each bound to a Chrome window with auto tab sync.",
  "permissions": [
    "tabs",
    "storage",
    "windows"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "Tab Workspace Manager - By WindManager",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
